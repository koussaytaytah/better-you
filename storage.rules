rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Post Images
    match /post_images/{imageId} {
      // Anyone can see the posted images
      allow read: if true;
      // Only authenticated users can upload new images
      allow write: if request.auth != null;
    }
    
    // Fallback rule for any other files
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
