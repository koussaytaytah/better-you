rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Functions for easier management
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users: Profiles are public for social features, but only owner can write
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Daily logs: Only owner can access
    match /daily_logs/{logId} {
      allow read, write: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId;
    }

    // Posts: Publicly readable, authenticated users can create, owner can update/delete
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }

    // Comments: Publicly readable, authenticated users can write
    match /comments/{commentId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Chat rooms: Participants only
    match /chat_rooms/{roomId} {
      allow read, update: if isAuthenticated() && 
        resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isAuthenticated();
    }

    // Messages: Must be a participant in the associated chat room
    match /messages/{messageId} {
      allow create: if isAuthenticated() && 
        get(/databases/$(database)/documents/chat_rooms/$(request.resource.data.roomId)).data.participants.hasAny([request.auth.uid]);
      allow read: if isAuthenticated() && 
        get(/databases/$(database)/documents/chat_rooms/$(resource.data.roomId)).data.participants.hasAny([request.auth.uid]);
    }

    // Notifications: Only recipient can read/update
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && 
        (resource.data.toUserId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
    }

    // Quests: Users can access their own
    match /quests/{questId} {
      allow read, write: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId;
    }

    // Default for everything else
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
